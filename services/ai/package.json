{
  "name": "@goldfinch/service-ai",
  "version": "0.1.0",
  "private": true,
  "description": "GoldFinch AI insights Lambda: rules-first transaction categorization with a Bedrock (Claude Haiku) fallback, plus the monthly cashflow summary generator.",
  "type": "module",
  "main": "./dist/src/handler.js",
  "types": "./dist/src/handler.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/*.test.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@goldfinch/shared": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
