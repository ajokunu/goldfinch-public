# StrykerJS mutation-testing artifacts (npm run test:mutation).
# reports/ holds the html/json reports AND the incremental-mode cache
# (reports/stryker-incremental.json) - machine-local, never committed.
.stryker-tmp/
reports/
stryker.log

# tsc test-compile output (npm test: `tsc -p tsconfig.test.json` into dist-test, then node --test).
# Build artifact, regenerated every test run; `npm run clean` removes it. Never commit.
dist-test/
