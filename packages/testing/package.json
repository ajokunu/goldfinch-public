{
  "name": "@goldfinch/testing",
  "version": "0.1.0",
  "private": true,
  "description": "Shared GoldFinch test utilities: DynamoDB item factories honoring the key builders, JWT claim and API Gateway event fixtures, SimpleFIN payload fixtures, and an in-memory DocumentClient fake. Also hosts the cross-workspace contract-drift integration suite.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@goldfinch/shared": "*"
  },
  "devDependencies": {
    "@goldfinch/api": "*",
    "@goldfinch/sync": "*",
    "@types/aws-lambda": "^8.10.140",
    "@types/node": "^20.14.0",
    "aws-sdk-client-mock": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
