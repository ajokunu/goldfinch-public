<?xml version="1.0" encoding="UTF-8"?>
<!--
  WidgetKit extension Info.plist for the GoldFinch home-screen widget
  (WIDGET-PLAN.md task 5). Standard app-extension shape: the only required
  NSExtension point for a WidgetKit extension is com.apple.widgetkit-extension.
  The @bacons/apple-targets plugin links the SwiftUI sources in this target dir
  and uses this plist verbatim (the root plist of a target dir is not managed).
  No emoji / plain labels only (house rule).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>GoldFinch Widget</string>
	<key>CFBundleName</key>
	<string>GoldFinchWidget</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.widgetkit-extension</string>
	</dict>
</dict>
</plist>
