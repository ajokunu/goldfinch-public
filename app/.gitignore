node_modules/
.expo/
dist/
web-build/
*.tsbuildinfo
.env
.env.*.local

# Native prebuild output at the app root (regenerated by `expo prebuild`).
# Anchored with a leading slash so NESTED module native dirs are NOT ignored --
# e.g. modules/widget-bridge/ios and modules/widget-bridge/android carry the
# WidgetBridge Expo module's Swift/Kotlin and MUST be committed for EAS to build
# the native module.
/ios/
/android/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# StrykerJS mutation-testing artifacts (npm run test:mutation) and the
# node:test harness build output (compiled by the per-package test scripts).
# NOTE: the reports/ entries are anchored on purpose -- features/reports is
# product source, only the Stryker report output dirs are ignored.
.stryker-tmp/
dist-test/
/reports/
/src/ui/charts/reports/
/src/i18n/reports/
stryker.log
