{
  "name": "@goldfinch/app",
  "version": "0.1.0",
  "private": true,
  "description": "GoldFinch Expo client (iOS / Android / Web) - app shell, auth, API layer, theme.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "export:web": "expo export -p web",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "npm run test:unit && npm run test:component",
    "test:unit": "tsc -p src/ui/tsconfig.test.json && node --test src/ui/dist-test/test/*.test.js && npm --prefix src/ui/charts test && npm --prefix src/i18n test && npm --prefix features/transactions test && npm --prefix features/goals test && npm --prefix features/budget test && npm --prefix features/dashboard test && npm --prefix features/reports test && npm --prefix features/investments test",
    "test:component": "tsc -p test/tsconfig.json && jest",
    "test:mutation": "npx --yes -p @stryker-mutator/core@9.6.1 -p @stryker-mutator/tap-runner@9.6.1 -- stryker run && npm --prefix src/ui/charts run test:mutation && npm --prefix src/i18n run test:mutation",
    "eas-build-post-install": "npm --prefix ../packages/shared run build",
    "doctor": "expo-doctor"
  },
  "dependencies": {
    "@expo-google-fonts/hanken-grotesk": "^0.4.3",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/newsreader": "^0.4.1",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo-google-fonts/schibsted-grotesk": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@goldfinch/shared": "*",
    "@react-navigation/native": "^7.1.6",
    "@shopify/flash-list": "~2.0.2",
    "@shopify/react-native-skia": "2.2.12",
    "@tanstack/react-query": "^5.59.16",
    "expo": "~54.0.0",
    "expo-application": "~7.0.0",
    "expo-auth-session": "~7.0.0",
    "expo-constants": "~18.0.0",
    "expo-crypto": "~15.0.0",
    "expo-device": "~8.0.0",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.0",
    "expo-local-authentication": "~17.0.0",
    "expo-network": "~8.0.0",
    "expo-notifications": "~0.32.0",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-splash-screen": "~31.0.0",
    "expo-status-bar": "~3.0.0",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.0",
    "lucide-react-native": "^0.511.0",
    "papaparse": "^5.5.0",
    "phosphor-react-native": "^3.0.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@bacons/apple-targets": "^4.0.7",
    "@goldfinch/testing": "*",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.0",
    "@types/papaparse": "^5.3.15",
    "@types/react": "~19.1.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
